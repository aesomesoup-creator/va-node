# === DATABASE ===
# Neon PostgreSQL connection string
# Get one at: https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# === GOOGLE OAUTH ===
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === SESSION ===
# Generate a strong random string
SESSION_SECRET=change_this_to_a_random_secret_string

# === APP ===
PORT=3001
# URL of THIS server (used to build the Google OAuth callback URL)
# In production: https://your-backend.railway.app  (no trailing slash)
SERVER_URL=http://localhost:3001
# URL of the frontend client (where to redirect after OAuth)
# In production: https://your-frontend.vercel.app
CLIENT_URL=http://localhost:5173
NODE_ENV=development
